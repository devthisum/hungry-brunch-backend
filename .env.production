# Copy these into Railway's environment variables panel
# DO NOT commit this file with real values

PORT=5000
DATABASE_URL=mysql://user:password@host:port/dbname   # Railway fills this automatically
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d
FRONTEND_URL=https://your-app-name.vercel.app         # Fill after Vercel deploy
NODE_ENV=production
